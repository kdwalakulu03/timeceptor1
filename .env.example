# ─────────────────────────────────────────────────────────────────────────
# Timeceptor — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored. This file (.env.example) IS committed.
# ─────────────────────────────────────────────────────────────────────────

# ── Firebase Client SDK (safe to expose in browser bundle) ───────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=timeceptor.com
VITE_FIREBASE_PROJECT_ID=timeceptor1
VITE_FIREBASE_STORAGE_BUCKET=timeceptor1.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=479329986961
VITE_FIREBASE_APP_ID=1:479329986961:web:21480d1cb5da6786ca5230
VITE_FIREBASE_MEASUREMENT_ID=G-CEBGBF1BCR

# ── Firebase Admin SDK (SERVER ONLY — never expose to browser) ───────────
# Download service account JSON from Firebase Console:
#   Project Settings → Service Accounts → Generate new private key
# Save the file as: data/firebase-service-account.json  (gitignored)
GOOGLE_APPLICATION_CREDENTIALS=./data/firebase-service-account.json
FIREBASE_PROJECT_ID=timeceptor1

# ── Server ────────────────────────────────────────────────────────────────
PORT=47000
NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://timeceptor:timeceptor@localhost:5432/timeceptor
# Set to true only if your PG server requires SSL (e.g. managed cloud DBs)
DATABASE_SSL=false

# ── Telegram Bot (optional — leave empty to disable) ─────────────────────
# Create via @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Web Push (VAPID keys) ────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:hello@timeceptor.com
# ── Stripe ($0.99 one-time payment — "Unlock Your Golden Hours") ─────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here
# Webhook signing secret (set up at https://dashboard.stripe.com/webhooks)
# Create a webhook listening to: checkout.session.completed
# Endpoint URL: https://timeceptor.com/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here