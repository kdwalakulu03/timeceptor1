{
  "name": "timeceptor",
  "description": "Vedic planetary timing for modern life — timeceptor.com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "PORT=47001 tsx watch server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx server/index.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:prefill-transits": "tsx server/jobs/transits.ts 365",
    "db:scores": "tsx server/jobs/score.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^5.0.4",
    "astronomy-engine": "^2.1.19",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.0",
    "stripe": "^22.0.0",
    "topojson-client": "^3.1.0",
    "vite": "^6.2.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
